---
import { featureCards } from '../data/site';
---

<section class="mx-auto max-w-6xl px-5 py-20">
  <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
    {
      featureCards.map((card) => (
        <a
          href={card.href}
          class="group flex flex-col overflow-hidden rounded-2xl border border-bark-200 bg-white shadow-sm transition-shadow hover:shadow-md"
        >
          <div class="aspect-[4/3] overflow-hidden bg-bark-100">
            <img
              src={card.image}
              alt={card.title}
              loading="lazy"
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
          </div>
          <div class="flex flex-1 flex-col p-6">
            <h3 class="text-2xl text-bark-800">{card.title}</h3>
            <p class="mt-3 text-bark-600">{card.body}</p>
          </div>
        </a>
      ))
    }
  </div>
</section>
