---
import { propertyStory } from '../data/site';
---

<section id="story" class="mx-auto max-w-6xl px-5 py-20">
  <header class="mx-auto mb-16 max-w-2xl text-center">
    <h2 class="text-3xl text-bark-800 sm:text-4xl">Our Story</h2>
    <p class="mt-4 text-bark-600">
      A house, a lake, and the land that holds them — told in four parts.
    </p>
  </header>

  <div class="space-y-20">
    {
      propertyStory.map((part, i) => (
        <article
          class:list={[
            'grid items-center gap-8 md:grid-cols-2 md:gap-12',
            i % 2 === 1 && 'md:[&>figure]:order-2',
          ]}
        >
          <figure class="overflow-hidden rounded-2xl border border-bark-200 bg-bark-100">
            <img
              src={part.image}
              alt={part.title}
              loading="lazy"
              class="aspect-[4/3] w-full object-cover"
            />
          </figure>
          <div>
            <h3 class="text-2xl text-bark-800 sm:text-3xl">{part.title}</h3>
            <div class="mt-4 space-y-4 text-lg text-bark-700">
              {part.body.map((para) => (
                <p>{para}</p>
              ))}
            </div>
          </div>
        </article>
      ))
    }
  </div>
</section>
