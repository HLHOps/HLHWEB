---
import { site } from '../data/site';
---

<section class="relative h-screen min-h-[600px] w-full overflow-hidden">
  <!-- Full-screen video background. Autoplay is driven by the script below so
       that prefers-reduced-motion users see the static poster instead of a
       moving background. The `autoplay` attribute is intentionally omitted. -->
  <video
    id="hero-video"
    class="absolute inset-0 h-full w-full object-cover"
    muted
    loop
    playsinline
    poster={site.heroPoster}
    aria-hidden="true"
  >
    <source src={site.heroVideo} type="video/mp4" />
  </video>

  <!-- Pause/play toggle for the background video. Unobtrusive by default,
       brighter on hover/focus, and always reachable by keyboard. -->
  <button
    id="hero-video-toggle"
    type="button"
    class="absolute bottom-6 right-6 z-20 flex h-11 w-11 items-center justify-center rounded-full border border-cream/60 bg-bark-900/40 text-cream opacity-70 backdrop-blur-sm transition hover:bg-bark-900/70 hover:opacity-100 focus-visible:opacity-100"
    aria-label="Pause background video"
    aria-pressed="false"
  >
    <svg
      class="hero-icon-pause h-5 w-5"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="currentColor"
      aria-hidden="true"
    >
      <rect x="6" y="5" width="4" height="14" rx="1"></rect>
      <rect x="14" y="5" width="4" height="14" rx="1"></rect>
    </svg>
    <svg
      class="hero-icon-play hidden h-5 w-5"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="currentColor"
      aria-hidden="true"
    >
      <path d="M8 5v14l11-7z"></path>
    </svg>
  </button>

  <!-- Warm gradient scrim for legibility -->
  <div
    class="absolute inset-0 bg-gradient-to-b from-bark-900/50 via-bark-900/30 to-bark-900/70"
  >
  </div>

  <!-- Title overlay -->
  <div
    class="relative flex h-full flex-col items-center justify-center px-6 text-center text-cream"
  >
    <h1
      class="max-w-4xl text-4xl leading-tight drop-shadow-lg sm:text-5xl md:text-6xl"
    >
      Welcome to Holliday Lake House
    </h1>
    <p
      class="mt-6 max-w-2xl text-lg text-cream/95 drop-shadow-md sm:text-xl md:text-2xl"
    >
      Discover a Unique Waterfront Getaway and Unforgettable Vacation Experience
    </p>
    <p
      class="mt-4 text-base uppercase tracking-[0.2em] text-gold-200 drop-shadow sm:text-lg"
    >
      Now Available for Short Term Rental
    </p>

    <a
      href="#contact"
      class="mt-10 rounded-full border border-cream/70 bg-cream/10 px-8 py-3 text-base text-cream backdrop-blur-sm transition-colors hover:bg-cream hover:text-bark-800"
    >
      Plan Your Stay
    </a>
  </div>

  <!-- Scroll cue -->
  <div
    class="absolute bottom-6 left-1/2 -translate-x-1/2 text-cream/80"
    aria-hidden="true"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="28"
      height="28"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M6 9l6 6 6-6"></path>
    </svg>
  </div>
</section>

<script>
  const video = document.getElementById('hero-video') as HTMLVideoElement | null;
  const toggle = document.getElementById('hero-video-toggle');

  if (video && toggle) {
    const pauseIcon = toggle.querySelector<HTMLElement>('.hero-icon-pause');
    const playIcon = toggle.querySelector<HTMLElement>('.hero-icon-play');
    const prefersReducedMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)',
    ).matches;

    function reflect(playing: boolean) {
      toggle!.setAttribute('aria-label', playing ? 'Pause background video' : 'Play background video');
      toggle!.setAttribute('aria-pressed', String(!playing));
      pauseIcon?.classList.toggle('hidden', !playing);
      playIcon?.classList.toggle('hidden', playing);
    }

    // Reduced-motion users get the static poster: never autoplay.
    if (prefersReducedMotion) {
      video.pause();
      reflect(false);
    } else {
      video.play().then(() => reflect(true)).catch(() => reflect(false));
    }

    toggle.addEventListener('click', () => {
      if (video.paused) {
        video.play().then(() => reflect(true)).catch(() => reflect(false));
      } else {
        video.pause();
        reflect(false);
      }
    });
  }
</script>
