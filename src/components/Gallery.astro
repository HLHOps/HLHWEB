---
import { galleryImages } from '../data/site';
---

<section id="gallery" class="bg-bark-50 py-20">
  <div class="mx-auto max-w-6xl px-5">
    <header class="mx-auto mb-12 max-w-2xl text-center">
      <h2 class="text-3xl text-bark-800 sm:text-4xl">A Look Around</h2>
      <p class="mt-4 text-bark-600">
        Water, woods, and warm rooms — a few glimpses of life at the lake house.
      </p>
    </header>

    <div class="columns-1 gap-4 sm:columns-2 lg:columns-3 [&>*]:mb-4">
      {
        galleryImages.map((img) => (
          <figure class="overflow-hidden rounded-xl border border-bark-200 bg-bark-100">
            <img
              src={img.src}
              alt={img.alt}
              loading="lazy"
              class="w-full object-cover"
            />
          </figure>
        ))
      }
    </div>
  </div>
</section>
