---
import { site } from '../data/site';
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-bark-200 bg-bark-800 text-bark-100">
  <div class="mx-auto max-w-6xl px-5 py-14">
    <div class="flex flex-col items-center gap-6 text-center">
      <p class="text-2xl text-cream">Holliday Lake House</p>

      <a
        href={site.instagramUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-bark-100 transition-colors hover:text-gold-300"
        aria-label={`Follow us on Instagram at ${site.instagramHandle} (opens in a new tab)`}
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
        </svg>
        <span>{site.instagramHandle}</span>
      </a>

      <p class="text-sm text-bark-300">
        &copy; {year} Holliday Lake House. All rights reserved.
      </p>
    </div>
  </div>
</footer>
