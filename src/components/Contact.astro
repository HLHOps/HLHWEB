---
import { site } from '../data/site';
---

<section id="contact" class="bg-bark-50 py-24">
  <div class="mx-auto max-w-3xl px-5 text-center">
    <h2 class="text-3xl text-bark-800 sm:text-4xl">Plan Your Stay</h2>
    <p class="mx-auto mt-5 max-w-xl text-lg text-bark-700">
      We would love to help you plan a stay at Holliday Lake House. Reach out
      with your dates, your group, and any questions — we will get back to you
      soon.
    </p>

    <a
      href={site.jotformUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-10 inline-block rounded-full bg-forest-600 px-10 py-4 text-lg text-cream shadow-sm transition-colors hover:bg-forest-700"
    >
      Get in Touch<span class="sr-only"> (opens in a new tab)</span>
    </a>

    <p class="mt-6 text-sm text-bark-600">
      Opens our inquiry form in a new tab.
    </p>
  </div>
</section>
