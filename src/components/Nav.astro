---
import { site, navLinks } from '../data/site';
---

<header
  class="sticky top-0 z-50 border-b border-bark-200/60 bg-cream/90 backdrop-blur supports-[backdrop-filter]:bg-cream/80"
>
  <nav
    class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4"
    aria-label="Primary"
  >
    <a
      href="/"
      class="text-lg tracking-wide text-bark-800 sm:text-xl"
    >
      <span class="font-semibold">Holliday</span> Lake House
    </a>

    <ul class="flex items-center gap-6 text-sm sm:text-base">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-bark-700 transition-colors hover:text-gold-700"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
