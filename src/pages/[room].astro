---
import Base from '../layouts/Base.astro';
import { rooms } from '../data/rooms';
import { site } from '../data/site';

export function getStaticPaths() {
  return rooms.map((room) => ({
    params: { room: room.slug },
    props: { room },
  }));
}

const { room } = Astro.props;
---

<Base
  title={`${room.name} — Holliday Lake House`}
  description={room.tagline}
>
  <!-- Room hero image -->
  <section class="relative h-[55vh] min-h-[360px] w-full overflow-hidden bg-bark-200">
    <img
      src={room.image}
      alt={room.name}
      class="absolute inset-0 h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-bark-900/70 via-bark-900/20 to-transparent"></div>
    <div class="relative flex h-full items-end">
      <div class="mx-auto w-full max-w-5xl px-5 pb-10 text-cream">
        <h1 class="text-4xl drop-shadow-md sm:text-5xl">{room.name}</h1>
        <p class="mt-3 text-lg text-cream/95 drop-shadow">{room.tagline}</p>
      </div>
    </div>
  </section>

  <article class="mx-auto max-w-5xl px-5 py-16">
    <a
      href="/#rooms"
      class="text-sm text-gold-700 transition-colors hover:text-bark-800"
    >
      &larr; All rooms
    </a>

    <!-- Quick facts -->
    <dl class="mt-8 grid grid-cols-1 gap-6 rounded-2xl border border-bark-200 bg-white p-6 sm:grid-cols-3">
      <div>
        <dt class="text-sm uppercase tracking-wide text-bark-400">Level</dt>
        <dd class="mt-1 text-lg text-bark-800">{room.floor}</dd>
      </div>
      <div>
        <dt class="text-sm uppercase tracking-wide text-bark-400">Beds</dt>
        <dd class="mt-1 text-lg text-bark-800">{room.beds}</dd>
      </div>
      <div>
        <dt class="text-sm uppercase tracking-wide text-bark-400">Sleeps</dt>
        <dd class="mt-1 text-lg text-bark-800">{room.capacity} guests</dd>
      </div>
    </dl>

    <!-- Description -->
    <div class="mt-12 max-w-2xl space-y-5 text-lg text-bark-700">
      {room.description.map((para) => <p>{para}</p>)}
    </div>

    <!-- Gallery -->
    {
      room.gallery.length > 0 && (
        <div class="mt-12 grid gap-4 sm:grid-cols-2">
          {room.gallery.map((src) => (
            <figure class="overflow-hidden rounded-xl border border-bark-200 bg-bark-100">
              <img
                src={src}
                alt={room.name}
                loading="lazy"
                class="aspect-[4/3] w-full object-cover"
              />
            </figure>
          ))}
        </div>
      )
    }

    <!-- CTA -->
    <div class="mt-16 rounded-2xl bg-bark-50 p-8 text-center">
      <h2 class="text-2xl text-bark-800">Make it yours</h2>
      <p class="mx-auto mt-3 max-w-xl text-bark-600">
        Interested in the {room.name} room for your stay? Reach out and we will
        help you plan the details.
      </p>
      <a
        href={site.jotformUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-6 inline-block rounded-full bg-forest-600 px-8 py-3 text-cream transition-colors hover:bg-forest-700"
      >
        Get in Touch
      </a>
    </div>
  </article>
</Base>
